<?xml version="1.0"?>
<sdf version="1.8">
  <model name="agv">
    <pose>0 0 0 0 0 0</pose>

    <link name="base_footprint"/>

    <link name="base_link">
      <inertial>
        <pose>0 0 0.08 0 0 0</pose>
        <mass>10.0</mass>
        <inertia>
          <ixx>0.15</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.28</iyy>
          <iyz>0.0</iyz>
          <izz>0.35</izz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <pose>0 0 0.08 0 0 0</pose>
        <geometry>
          <box>
            <size>0.5 0.35 0.12</size>
          </box>
        </geometry>
      </collision>

      <visual name="base_visual">
        <pose>0 0 0.08 0 0 0</pose>
        <geometry>
          <box>
            <size>0.5 0.35 0.12</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.3 0.8 1.0</ambient>
          <diffuse>0.1 0.3 0.8 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="left_wheel_link">
      <inertial>
        <pose>0 0 0 -1.5708 0 0</pose>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.002</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.001</iyy>
          <iyz>0.0</iyz>
          <izz>0.002</izz>
        </inertia>
      </inertial>

      <collision name="left_wheel_collision">
        <pose>0 0 0 -1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.07</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>100.0</mu>
              <mu2>100.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="left_wheel_visual">
        <pose>0 0 0 -1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.07</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1.0</ambient>
          <diffuse>0.1 0.1 0.1 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="right_wheel_link">
      <inertial>
        <pose>0 0 0 -1.5708 0 0</pose>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.002</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.001</iyy>
          <iyz>0.0</iyz>
          <izz>0.002</izz>
        </inertia>
      </inertial>

      <collision name="right_wheel_collision">
        <pose>0 0 0 -1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.07</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>100.0</mu>
              <mu2>100.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="right_wheel_visual">
        <pose>0 0 0 -1.5708 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.07</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1.0</ambient>
          <diffuse>0.1 0.1 0.1 1.0</diffuse>
        </material>
      </visual>
    </link>

    <link name="caster_wheel_link">
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0008</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.0008</iyy>
          <iyz>0.0</iyz>
          <izz>0.0008</izz>
        </inertia>
      </inertial>

      <collision name="caster_wheel_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.05</mu>
              <mu2>0.05</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="caster_wheel_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.6 0.6 0.6 1.0</ambient>
          <diffuse>0.6 0.6 0.6 1.0</diffuse>
        </material>
      </visual>
    </link>

    <joint name="base_joint" type="fixed">
      <parent>base_footprint</parent>
      <child>base_link</child>
      <pose>0 0 0 0 0 0</pose>
    </joint>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel_link</child>
      <pose>0 0.19 0.07 -1.5708 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <effort>20</effort>
        </limit>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel_link</child>
      <pose>0 -0.19 0.07 -1.5708 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <effort>20</effort>
        </limit>
      </axis>
    </joint>

    <joint name="caster_wheel_joint" type="fixed">
      <parent>base_link</parent>
      <child>caster_wheel_link</child>
      <pose>-0.18 0 0.04 0 0 0</pose>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.38</wheel_separation>
      <wheel_radius>0.07</wheel_radius>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publisher_frequency>30</odom_publisher_frequency>
      <tf_topic>tf</tf_topic>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </model>
</sdf>
